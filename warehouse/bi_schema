import pandas as pd
from sqlalchemy import create_engine
engine = create_engine('postgresql://user:pass@localhost:5432/analytics_db')

def load_to_bi():
    df = pd.read_csv("../clean/cleaned_avito_data.csv")
    with engine.connect() as conn:
        conn.execute("CREATE SCHEMA IF NOT EXISTS bi_schema;")
    
    df.to_sql('dim_properties', engine, schema='bi_schema', if_exists='replace')
    print(" Données nettoyées et enregistrées sous le répertoire clean.")

if __name__ == "__main__":
    load_to_bi()